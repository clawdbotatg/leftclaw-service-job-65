# Template for NextJS environment variables.
#
# For local development: copy to `.env.local` in this folder and fill in.
# For production / IPFS builds: set these in your shell before `yarn build`, e.g.
#   NEXT_PUBLIC_ALCHEMY_API_KEY=... NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=... yarn build
#
# All `NEXT_PUBLIC_` vars are baked into the static bundle at build time.

# Alchemy API key for Base mainnet (and any other chain in `scaffold.config.ts`).
# Required for production: the default key is shared and rate-limited.
# Get one at https://dashboard.alchemy.com/.
NEXT_PUBLIC_ALCHEMY_API_KEY=

# WalletConnect Cloud project ID. Required for production: the default is
# SE2's shared public key and will throttle / break mobile deep links.
# Provision at https://cloud.walletconnect.com/ and paste the Project ID here.
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Absolute origin used for OG / Twitter card URLs (e.g. https://updown.example).
# Leave blank in local dev; set when deploying to a live domain.
NEXT_PUBLIC_PRODUCTION_URL=

